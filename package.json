{
  "name": "moonrepo-cli",
  "version": "1.0.0",
  "description": "Scaffold a pnpm + Turbo monorepo in seconds",
  "type": "module",
  "bin": {
    "create-moonrepo": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node src/index.ts",
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "files": [
    "src"
  ],
  "keywords": [
    "monorepo",
    "turbo",
    "pnpm",
    "scaffold",
    "cli"
  ],
  "author": "https://github.com/SebasSoftware",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "handlebars": "^4.7.9",
    "inquirer": "^14.0.2",
    "ora": "^9.4.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3"
  }
}
